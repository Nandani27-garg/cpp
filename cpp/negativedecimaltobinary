/*-ve decimal to binary*/

#include <iostream>
#include <math.h>
using namespace std;

int main() {
    int n;
    cout<<"Enter a negative decimal number: ";
    cin>>n;
    n = abs(n);
    int ans=0, i=0; 
    while(n!=0){
        int digit = n&1;
        {
            ans = ans +(digit= pow(10,i));
    }
        
        i++;
        n = n >>1;
         
     }
     cout<<"The binary equivalent is: "<<ans<<endl;
}